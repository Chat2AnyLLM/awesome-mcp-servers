{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Chat2AnyLLM/awesome-mcp-servers/schema/mcp-server.schema.json",
  "title": "MCP Server",
  "description": "Schema for a single curated MCP server entry",
  "type": "object",
  "required": ["description"],
  "additionalProperties": true,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "URL-safe identifier, must match the filename"
    },
    "name": {
      "type": "string",
      "description": "CAM-compatible MCP server identifier, must match the filename when slug is absent"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "url": {
      "type": "string",
      "pattern": "^https?://",
      "description": "URL to the MCP server repository or documentation"
    },
    "repository": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "homepage": {
      "type": ["string", "null"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "ai-ml",
        "databases",
        "file-systems",
        "version-control",
        "communication",
        "cloud-platforms",
        "developer-tools",
        "web",
        "productivity",
        "security",
        "data",
        "other"
      ]
    },
    "author": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" }
          }
        }
      ]
    },
    "npm": {
      "type": "string",
      "description": "NPM package name if installable via npx"
    },
    "docker": {
      "type": "string",
      "description": "Docker image name if available as a container"
    },
    "license": {
      "type": "string",
      "description": "License identifier (e.g., MIT, Apache-2.0)"
    },
    "categories": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "installations": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "type": { "type": "string" },
          "command": { "type": "string" },
          "args": {
            "type": "array",
            "items": { "type": "string" }
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "url": { "type": "string" },
          "headers": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "arguments": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "anyOf": [
    { "required": ["slug", "title", "url", "tags", "category", "author"] },
    { "required": ["name", "installations"] }
  ]
}
